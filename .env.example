# Copy this file to .env and fill in your API keys
# .env is gitignored and will NOT be committed

# LLM Provider — set ONE of these to activate that provider
# If both are set, Anthropic takes precedence
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional — override default model names
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_MODEL=gpt-4o

# Optional — Pinecone vector store (falls back to in-memory if blank)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
