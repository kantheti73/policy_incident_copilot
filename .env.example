# Copy this file to .env and fill in your Doppler service token.
# .env is gitignored and will NOT be committed.
#
# Secret management strategy:
#   - Sensitive secrets (API keys) live in Doppler
#   - The container fetches them at startup using the Doppler CLI
#   - The only thing on your laptop is the Doppler bootstrap token below
#
# Setup steps:
#   1. Sign up at https://doppler.com and create a project
#   2. Add these secrets to your Doppler config:
#        ANTHROPIC_API_KEY (or OPENAI_API_KEY)
#        PINECONE_API_KEY (optional — only if using Pinecone)
#   3. Generate a Service Token (read-only) for your config
#   4. Paste the token below

# Bootstrap credential for Doppler — the only secret on your laptop
DOPPLER_TOKEN=

# Non-secret config (safe to keep in .env)
PINECONE_ENVIRONMENT=us-east-1

# Planner Agent — lightweight local model via Ollama (default: phi3:mini)
PLANNER_LOCAL_ENABLED=true
PLANNER_MODEL=phi3:mini

# Optional — override default model names
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_MODEL=gpt-4o
