# Copy this file to .env and fill in your API keys
# .env is gitignored and will NOT be committed

# Primary LLM Provider (for Researcher, Orchestrator, Critic, PolicyQuery agents)
# Set ONE of these to activate that provider. If both are set, Anthropic takes precedence.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional — override default model names
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_MODEL=gpt-4o

# Planner Agent — uses a lightweight local model via Ollama (default: phi3:mini)
# The Ollama sidecar runs automatically via docker-compose and pulls the model on first start.
# Set PLANNER_LOCAL_ENABLED=false to disable and reuse the primary model for planning.
PLANNER_LOCAL_ENABLED=true
PLANNER_MODEL=phi3:mini
# OLLAMA_BASE_URL=http://ollama:11434

# Optional — Pinecone vector store (falls back to in-memory if blank)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
