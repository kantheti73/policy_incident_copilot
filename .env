# Bootstrap credential for Doppler — this is the ONLY secret on your laptop.
# All other API keys (ANTHROPIC_API_KEY, OPENAI_API_KEY, PINECONE_API_KEY)
# live in Doppler and are fetched at container startup by the Doppler CLI.
#
# Generate a service token at: https://dashboard.doppler.com
# Project: policy_incident_copilot_project
# Config:  dev_personal
DOPPLER_TOKEN=

# Non-secret config (safe to keep here)
PINECONE_ENVIRONMENT=us-east-1

# Planner Agent — lightweight local model via Ollama (default: phi3:mini)
PLANNER_LOCAL_ENABLED=true
PLANNER_MODEL=phi3:mini

# Optional — override default model names
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_MODEL=gpt-4o
